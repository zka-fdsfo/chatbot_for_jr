# Backend
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/customer-engagement-platform
CLIENT_URL=http://localhost:5173

# Authentication
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Seed script (backend/scripts/seedAdmin.js) — bootstraps the first admin user
SEED_ADMIN_NAME=Platform Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!

# Anonymous visitor sessions (separate secret — never interchangeable with JWT_SECRET)
VISITOR_TOKEN_SECRET=
VISITOR_SESSION_TIMEOUT=30d

# AI
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=800
AI_KNOWLEDGE_LIMIT=3

# Frontend (exposed to client bundle via Vite's VITE_ prefix)
VITE_API_BASE_URL=http://localhost:5000/api/v1
VITE_SOCKET_URL=http://localhost:5000
